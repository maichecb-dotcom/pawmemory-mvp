# Copy this file to .env on the Tencent Cloud server.
# Do not commit the real .env file.

PORT=3000

# AI provider: deepseek is recommended for mainland China users.
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-chat

# Keep these while PawMemory still uses Supabase for login and cloud data.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key_here

# Optional, only if AI_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
